# Copy to .env and adjust. `docker compose` reads .env automatically.

# Host directory where you drop the IC-7610 .wav files (mounted read-write so
# the trash-can delete works).
RECORDINGS_DIR=/data1/recordings/incoming

# Host port to publish the UI on (container always listens on 8000 internally).
# Change this if 8080 is already used by another container on the host.
WEB_PORT=8080

# --- Transcription engine ---
# faster_whisper (default) | transformers  <-- flip to transformers if faster_whisper
# errors on Blackwell with "no kernel image is available for execution".
WHISPER_ENGINE=faster_whisper
WHISPER_MODEL=large-v3
DEVICE=cuda
COMPUTE_TYPE=float16
LANGUAGE=en
BEAM_SIZE=5
VAD=true

# --- Audio recovery / pre-cleaning ---
# Pre-clean audio (band-limit + denoise + normalize) before transcription to pull
# speech out of weak/noisy signals. Off by default so clean audio isn't altered;
# toggle per-file in the UI's re-transcribe control, or default it on here.
PREPROCESS=false
# ffmpeg filter chain used when PREPROCESS is on (override the whole chain if you like):
PREPROCESS_FILTERS=highpass=f=250,lowpass=f=3000,afftdn=nf=-20,dynaudnorm=f=150:g=15

# --- Scanner ---
SCAN_INTERVAL=30
STABLE_SECONDS=15
# Default for the UI "Scan recursively" toggle (you can flip it live in the UI).
SCAN_RECURSIVE=true

# --- Logging ---
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_MAX_BYTES=5242880   # rotate the log file at 5 MB
LOG_BACKUPS=5           # keep this many rotated files
LOG_BUFFER_LINES=2000   # lines retained in memory for the in-UI log panel
