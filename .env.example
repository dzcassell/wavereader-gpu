# Copy to .env and adjust. `docker compose` reads .env automatically.

# Host directory where you drop the IC-7610 .wav files (mounted read-only).
RECORDINGS_DIR=/opt/wavereader/recordings

# --- Transcription engine ---
# faster_whisper (default) | transformers  <-- flip to transformers if faster_whisper
# errors on Blackwell with "no kernel image is available for execution".
WHISPER_ENGINE=faster_whisper
WHISPER_MODEL=large-v3
DEVICE=cuda
COMPUTE_TYPE=float16
LANGUAGE=en
BEAM_SIZE=5
VAD=true

# --- Scanner ---
SCAN_INTERVAL=30
STABLE_SECONDS=15
